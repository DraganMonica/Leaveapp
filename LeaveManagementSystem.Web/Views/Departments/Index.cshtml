@model List<LeaveManagementSystem.Data.Department>
@{
    ViewData["Title"] = "Departments";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Departments</h4>
    <a asp-action="Create" class="btn btn-primary">+ Add Department</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Manager</th>
            <th>Employees</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dept in Model)
        {
            <tr>
                <td>@dept.Name</td>
                <td>@(dept.Manager != null ? $"{dept.Manager.FirstName} {dept.Manager.LastName}" : "No manager")</td>
                <td>@dept.Employees?.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@dept.Id" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="ManageEmployees" asp-route-id="@dept.Id" class="btn btn-sm btn-info">Employees</a>
                </td>
            </tr>
        }
    </tbody>
</table>
