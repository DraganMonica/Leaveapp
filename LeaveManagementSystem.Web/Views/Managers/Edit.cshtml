@model LeaveManagementSystem.Application.Models.Managers.EditManagerVM
@{
    ViewData["Title"] = "Edit Manager";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4>Edit Manager</h4>
<form method="post" asp-route-id="@ViewBag.UserId">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Date of Birth</label>
        <input type="date" name="DateOfBirth" class="form-control"
               value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
    </div>
    <div class="mb-3">
        <label>Date of Employment</label>
        <input type="date" name="DateOfEmployment" class="form-control"
               value="@Model.DateOfEmployment.ToString("yyyy-MM-dd")" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
