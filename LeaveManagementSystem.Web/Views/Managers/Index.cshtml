@model LeaveManagementSystem.Application.Models.Managers.ManagersListVM
@{
    ViewData["Title"] = "Managers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Managers & General Managers</h4>
    <div class="d-flex gap-2">
        <a asp-action="CreateManager" class="btn btn-primary">+ Add Manager</a>
        <a asp-action="CreateGeneralManager" class="btn btn-success">+ Add General Manager</a>
    </div>
</div>

<h5 class="mt-3">Managers</h5>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model.Managers)
        {
            <tr>
                <td>@m.FirstName @m.LastName</td>
                <td>@m.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form method="post" asp-action="Delete" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@m.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<h5 class="mt-4">General Managers</h5>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var gm in Model.GeneralManagers)
        {
            <tr>
                <td>@gm.FirstName @gm.LastName</td>
                <td>@gm.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@gm.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="ManageManagers" asp-route-id="@gm.Id" class="btn btn-sm btn-info">Managers</a>
                    <form method="post" asp-action="Delete" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@gm.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
