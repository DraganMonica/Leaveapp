@model List<LeaveManagementSystem.Data.PublicHoliday>
@{
    ViewData["Title"] = "Public Holidays";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Public Holidays @ViewBag.Year</h4>
    <a asp-action="Create" class="btn btn-primary">+ Add Holiday</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var holiday in Model)
        {
            <tr>
                <td>@holiday.Name</td>
                <td>@holiday.Date.ToString("dd MMM yyyy")</td>
                <td>
                    <form method="post" asp-action="Delete" asp-route-id="@holiday.Id" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
